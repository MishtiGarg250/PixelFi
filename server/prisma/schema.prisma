generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  clerkUserId  String            @unique
  email        String            @unique
  firstName    String?
  lastName     String?
  imageUrl     String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  baseCurrency String            @default("USD")
  username     String?           @unique
  insights     AIInsight[]
  accounts     Account[]
  customAssets CustomAsset[]
  expenses     Expense[]
  goals        Goal[]
  liabilities  Liability[]
  portfolios   Portfolio[]
  transactions Transaction[]
  marketAssets UserMarketAsset[]
}

model Account {
  id           String        @id @default(cuid())
  name         String
  brokerName   String?
  accountType  AccountType
  currency     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
}

model MarketAsset {
  id           String            @id @default(cuid())
  symbol       String            @unique
  name         String
  assetType    MarketAssetType
  exchange     String?
  sector       String?
  currency     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactions Transaction[]
  userAssets   UserMarketAsset[]

  @@index([symbol])
}

model UserMarketAsset {
  id            String                 @id @default(cuid())
  userId        String
  marketAssetId String
  quantity      Decimal                @db.Decimal(18, 4)
  averageCost   Decimal                @db.Decimal(18, 4)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  portfolios    PortfolioMarketAsset[]
  marketAsset   MarketAsset            @relation(fields: [marketAssetId], references: [id])
  user          User                   @relation(fields: [userId], references: [id])

  @@unique([userId, marketAssetId])
  @@index([userId])
  @@index([marketAssetId])
}

model CustomAsset {
  id            String              @id @default(cuid())
  userId        String
  portfolioId   String?
  name          String
  description   String?
  category      CustomAssetCategory
  currentValue  Decimal             @db.Decimal(18, 2)
  purchasePrice Decimal?            @db.Decimal(18, 2)
  purchaseDate  DateTime?
  currency      String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  portfolio     Portfolio?          @relation(fields: [portfolioId], references: [id])
  user          User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([portfolioId])
}

model Transaction {
  id            String          @id @default(cuid())
  accountId     String
  type          TransactionType
  quantity      Decimal?        @db.Decimal(18, 4)
  price         Decimal?        @db.Decimal(18, 4)
  fees          Decimal         @default(0) @db.Decimal(18, 4)
  currency      String
  executedAt    DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  marketAssetId String?
  amount        Decimal?        @db.Decimal(18, 2)
  userId        String
  account       Account         @relation(fields: [accountId], references: [id])
  marketAsset   MarketAsset?    @relation(fields: [marketAssetId], references: [id])
  user          User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([marketAssetId])
  @@index([executedAt])
}

model Liability {
  id             String        @id @default(cuid())
  userId         String
  name           String
  type           LiabilityType
  originalAmount Decimal       @db.Decimal(18, 2)
  outstanding    Decimal       @db.Decimal(18, 2)
  interestRate   Decimal?      @db.Decimal(5, 2)
  currency       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Portfolio {
  id           String                 @id @default(cuid())
  userId       String
  name         String
  description  String?
  visibility   PortfolioVisibility    @default(PRIVATE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  customAssets CustomAsset[]
  user         User                   @relation(fields: [userId], references: [id])
  marketAssets PortfolioMarketAsset[]

  @@index([userId])
}

model PortfolioMarketAsset {
  portfolioId       String
  userMarketAssetId String
  portfolio         Portfolio       @relation(fields: [portfolioId], references: [id])
  userMarketAsset   UserMarketAsset @relation(fields: [userMarketAssetId], references: [id])

  @@id([portfolioId, userMarketAssetId])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  title         String
  targetAmount  Decimal   @db.Decimal(18, 2)
  currentAmount Decimal   @default(0) @db.Decimal(18, 2)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Expense {
  id         String   @id @default(cuid())
  userId     String
  category   String
  title      String?
  amount     Decimal  @db.Decimal(18, 2)
  currency   String
  occurredAt DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([occurredAt])
}

model AIInsight {
  id          String          @id @default(cuid())
  userId      String
  type        InsightType
  severity    InsightSeverity
  title       String
  description String
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum MarketAssetType {
  STOCK
  ETF
  CRYPTO
  BOND
  MUTUAL_FUND
}

enum CustomAssetCategory {
  REAL_ESTATE
  VEHICLE
  LUXURY_ITEM
  ART
  COLLECTIBLE
  OTHER
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  DEPOSIT
  WITHDRAWAL
  INTEREST
  TRANSFER
}

enum AccountType {
  BROKERAGE
  BANK
  CRYPTO
}

enum PortfolioVisibility {
  PRIVATE
  PUBLIC
}

enum LiabilityType {
  MORTGAGE
  CAR_LOAN
  PERSONAL_LOAN
  CREDIT_CARD
  OTHER
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
}

enum InsightType {
  RISK
  DIVERSIFICATION
  PERFORMANCE
  SAVINGS
  MARKET
}
