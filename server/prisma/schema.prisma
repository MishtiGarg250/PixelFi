generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  clerkUserId  String        @unique
  email        String        @unique
  firstName    String?
  lastName     String?
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  baseCurrency String        @default("USD")
  username     String?       @unique
  insights     AIInsight[]
  customAssets CustomAsset[]
  expenses     Expense[]
  goals        Goal[]
  portfolios   Portfolio[]
}

model Portfolio {
  id           String              @id @default(cuid())
  userId       String
  name         String
  description  String?
  visibility   PortfolioVisibility @default(PRIVATE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  accounts     Account[]
  customAssets CustomAsset[]
  holdings     Holding[]
  user         User                @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Account {
  id           String        @id @default(cuid())
  portfolioId  String
  name         String
  brokerName   String
  accountType  AccountType
  currency     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id])
  transactions Transaction[]

  @@index([portfolioId])
}

model MarketAsset {
  id           String          @id @default(cuid())
  symbol       String          @unique
  name         String
  assetType    MarketAssetType
  exchange     String?
  sector       String?
  currency     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  holdings     Holding[]
  marketData   MarketData[]
  transactions Transaction[]

  @@index([symbol])
}

model CustomAsset {
  id            String              @id @default(cuid())
  userId        String
  portfolioId   String
  name          String
  description   String?
  category      CustomAssetCategory
  currentValue  Decimal             @db.Decimal(18, 2)
  purchasePrice Decimal?            @db.Decimal(18, 2)
  purchaseDate  DateTime?
  currency      String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  portfolio     Portfolio           @relation(fields: [portfolioId], references: [id])
  user          User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([portfolioId])
}

model Transaction {
  id            String          @id @default(cuid())
  accountId     String
  type          TransactionType
  quantity      Decimal         @db.Decimal(18, 4)
  price         Decimal         @db.Decimal(18, 4)
  fees          Decimal         @default(0) @db.Decimal(18, 4)
  currency      String
  executedAt    DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  marketAssetId String
  account       Account         @relation(fields: [accountId], references: [id])
  marketAsset   MarketAsset     @relation(fields: [marketAssetId], references: [id])

  @@index([accountId])
  @@index([marketAssetId])
  @@index([executedAt])
}

model Holding {
  id            String      @id @default(cuid())
  portfolioId   String
  quantity      Decimal     @db.Decimal(18, 4)
  averageCost   Decimal     @db.Decimal(18, 4)
  updatedAt     DateTime    @updatedAt
  marketAssetId String
  marketAsset   MarketAsset @relation(fields: [marketAssetId], references: [id])
  portfolio     Portfolio   @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId, marketAssetId])
  @@index([portfolioId])
  @@index([marketAssetId])
}

model MarketData {
  id            String      @id @default(cuid())
  price         Decimal     @db.Decimal(18, 4)
  currency      String
  marketCap     Decimal?    @db.Decimal(20, 2)
  volume        Decimal?    @db.Decimal(20, 2)
  fetchedAt     DateTime
  marketAssetId String
  marketAsset   MarketAsset @relation(fields: [marketAssetId], references: [id])

  @@index([marketAssetId, fetchedAt])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  title         String
  targetAmount  Decimal   @db.Decimal(18, 2)
  currentAmount Decimal   @default(0) @db.Decimal(18, 2)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Expense {
  id         String   @id @default(cuid())
  userId     String
  category   String
  title      String?
  amount     Decimal  @db.Decimal(18, 2)
  currency   String
  occurredAt DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([occurredAt])
}

model AIInsight {
  id          String          @id @default(cuid())
  userId      String
  type        InsightType
  severity    InsightSeverity
  title       String
  description String
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum MarketAssetType {
  STOCK
  ETF
  CRYPTO
  BOND
  MUTUAL_FUND
}

enum CustomAssetCategory {
  REAL_ESTATE
  VEHICLE
  LUXURY_ITEM
  ART
  COLLECTIBLE
  OTHER
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  DEPOSIT
  WITHDRAWAL
}

enum AccountType {
  BROKERAGE
  BANK
  CRYPTO
}

enum PortfolioVisibility {
  PRIVATE
  PUBLIC
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
}

enum InsightType {
  RISK
  DIVERSIFICATION
  PERFORMANCE
  SAVINGS
  MARKET
}
