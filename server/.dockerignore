.env.*
!.env.example

# Git
.git/
.gitignore

# Editor metadata
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test output
coverage/
